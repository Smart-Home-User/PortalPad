<resources>
    <!-- Splash screen theme (androidx core-splashscreen). On Android 12+ the
         system shows the animated icon on a solid brand-color background; on
         older versions it falls back to the branded gradient windowBackground.
         postSplashScreenTheme hands off to the normal app theme. The animated
         icon is centered by the OS, so this is orientation-safe by design. -->
    <style name="Theme.PortalPad.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F0A1A</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/avd_splash_logo</item>
        <item name="windowSplashScreenAnimationDuration">720</item>
        <item name="postSplashScreenTheme">@style/Theme.PortalPad</item>
        <!-- Pre-12 fallback: branded gradient behind the static icon. -->
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">#0F0A1A</item>
        <item name="android:navigationBarColor">#0F0A1A</item>
    </style>

    <style name="Theme.PortalPad" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="Theme.PortalPad.Trackpad" parent="Theme.PortalPad">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- For activities launched from the dock (search/mic, app picker): paint the
         window with the actual Compose background color (AbBackground = #0F0A1A)
         from the very first frame, instead of the default black. Removes the
         black→content flash so the screen looks "instantly there" while Compose
         finishes its first composition. -->
    <style name="Theme.PortalPad.FastLaunch" parent="Theme.PortalPad">
        <item name="android:windowBackground">#0F0A1A</item>
    </style>

</resources>
